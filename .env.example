# WhatsDeX Enhanced Configuration
# Copy this file to .env and fill in your actual values

# Database Configuration
DATABASE_URL="postgresql://username:password@localhost:5432/whatsdex?schema=public"

# Redis Configuration
REDIS_URL="redis://localhost:6379"
REDIS_PASSWORD=""

# JWT Configuration
JWT_SECRET="your-super-secret-jwt-key-here"
JWT_EXPIRES_IN="7d"

# AI API Keys
OPENAI_API_KEY="sk-your-openai-api-key"
GOOGLE_GEMINI_API_KEY="your-google-gemini-api-key-here"
STRIPE_SECRET_KEY="sk_test_your-stripe-secret-key"
STRIPE_WEBHOOK_SECRET="whsec_your-webhook-secret"

# Sentry Configuration (for error tracking)
SENTRY_DSN="https://your-sentry-dsn@sentry.io/project-id"

# Server Configuration
PORT=3000
NODE_ENV="development"

# WhatsApp Configuration (from existing config.js)
# These will be migrated from your existing config

# External Services
GOOGLE_CLOUD_API_KEY=""
FIREBASE_PROJECT_ID=""
TELEGRAM_BOT_TOKEN=""
DISCORD_BOT_TOKEN=""

# Security
BCRYPT_ROUNDS=12
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# File Upload
MAX_FILE_SIZE=10485760
UPLOAD_PATH="./uploads"

# Analytics
ANALYTICS_ENABLED=true
GA_TRACKING_ID=""

# Email Configuration (for notifications)
SMTP_HOST=""
SMTP_PORT=587
SMTP_USER=""
SMTP_PASS=""
FROM_EMAIL="noreply@whatsdex.com"

# Backup Configuration
BACKUP_ENABLED=true
BACKUP_SCHEDULE="0 2 * * *"
BACKUP_RETENTION_DAYS=30

# Plugin System
PLUGINS_ENABLED=true
PLUGINS_PATH="./plugins"

# Monitoring
HEALTH_CHECK_ENABLED=true
METRICS_ENABLED=true