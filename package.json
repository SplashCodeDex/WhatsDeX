{
  "name": "whatsdex-root",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "install:all": "pnpm install",
    "dev:frontend": "pnpm --filter frontend dev",
    "dev:backend": "pnpm --filter backend dev",
    "build:frontend": "pnpm --filter frontend build",
    "build:backend": "pnpm --filter backend build",
    "lint:frontend": "pnpm --filter frontend lint",
    "lint:backend": "pnpm --filter backend lint",
    "test:frontend": "pnpm --filter frontend test",
    "test:backend": "pnpm --filter backend test",
    "test:all": "pnpm --filter backend test && pnpm --filter frontend test",
    "typecheck": "pnpm --filter backend typecheck",
    "test:run": "pnpm --filter backend test:run",
    "sync:report": "tsx scripts/automation/upstream-watcher.ts"
  },
  "devDependencies": {
    "@types/node": "^25.3.5",
    "lightningcss": "^1.30.2",
    "tsx": "^4.21.0"
  },
  "pnpm": {
    "minimumReleaseAge": 2880,
    "overrides": {
      "wa-sticker-formatter>axios": "^1.7.9",
      "wa-sticker-formatter>sharp": "^0.33.5",
      "punycode": "npm:punycode@^2.3.1",
      "hono": "4.11.10",
      "fast-xml-parser": "5.3.6",
      "request": "npm:@cypress/request@3.0.10",
      "request-promise": "npm:@cypress/request-promise@5.0.0",
      "form-data": "2.5.4",
      "minimatch": "10.2.4",
      "qs": "6.14.2",
      "node-domexception": "npm:@nolyfill/domexception@^1.0.28",
      "@sinclair/typebox": "0.34.48",
      "tar": "7.5.9",
      "tough-cookie": "4.1.3"
    },
    "onlyBuiltDependencies": [
      "@lydell/node-pty",
      "@matrix-org/matrix-sdk-crypto-nodejs",
      "@napi-rs/canvas",
      "@whiskeysockets/baileys",
      "authenticate-pam",
      "esbuild",
      "koffi",
      "node-llama-cpp",
      "protobufjs",
      "sharp"
    ]
  }
}
